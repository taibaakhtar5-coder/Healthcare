@model PatientListViewModel
@{
    ViewData["Title"] = "Patients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2"></i>Patients
        <span class="badge bg-secondary fs-6 ms-2">@Model.TotalCount</span>
    </h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Receptionist"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus me-2"></i>New Patient
        </a>
    }
</div>

<!-- Search Form -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input name="SearchTerm" value="@Model.Search.SearchTerm"
                           class="form-control" placeholder="Name, code, phone, email…" />
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Gender</label>
                <select name="Gender" class="form-select">
                    <option value="">All</option>
                    @foreach (var g in Enum.GetValues<HealthcareCRM.Models.Gender>())
                    {
                        <option value="@g" @(Model.Search.Gender == g ? "selected" : "")>@g</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Blood Group</label>
                <select name="BloodGroup" class="form-select">
                    <option value="">All</option>
                    @foreach (var bg in new[] { "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-" })
                    {
                        <option value="@bg" @(Model.Search.BloodGroup == bg ? "selected" : "")>@bg</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Sort By</label>
                <select name="SortBy" class="form-select">
                    <option value="name"         @(Model.Search.SortBy == "name"         ? "selected" : "")>Name A–Z</option>
                    <option value="name_desc"    @(Model.Search.SortBy == "name_desc"    ? "selected" : "")>Name Z–A</option>
                    <option value="created_desc" @(Model.Search.SortBy == "created_desc" ? "selected" : "")>Newest First</option>
                    <option value="dob"          @(Model.Search.SortBy == "dob"          ? "selected" : "")>Age (Youngest)</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Results Table -->
@if (!Model.Patients.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-person-x" style="font-size:3rem;"></i>
        <p class="mt-2">No patients found.</p>
        <a asp-action="Create" class="btn btn-outline-primary mt-1">Add First Patient</a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Age / DOB</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Blood Group</th>
                            <th>City</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in Model.Patients)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@patient.PatientCode</span></td>
                                <td class="fw-semibold">@patient.FullName</td>
                                <td>@patient.Age yrs <small class="text-muted">(@patient.DateOfBirth.ToString("dd MMM yyyy"))</small></td>
                                <td>@patient.Gender</td>
                                <td>@patient.PhoneNumber</td>
                                <td>@(patient.BloodGroup ?? "—")</td>
                                <td>@(patient.City ?? "—")</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@patient.Id"
                                       class="btn btn-sm btn-outline-primary me-1" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Receptionist"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@patient.Id"
                                           class="btn btn-sm btn-outline-secondary me-1" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@patient.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    title="Deactivate"
                                                    onclick="return confirm('Deactivate patient @Html.Raw(patient.FullName)?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-SearchTerm="@Model.Search.SearchTerm"
                           asp-route-Gender="@Model.Search.Gender"
                           asp-route-BloodGroup="@Model.Search.BloodGroup"
                           asp-route-SortBy="@Model.Search.SortBy"
                           asp-route-Page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
