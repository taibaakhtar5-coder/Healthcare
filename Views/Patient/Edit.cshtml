@model PatientEditViewModel
@{
    ViewData["Title"] = "Edit Patient";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0">
        <i class="bi bi-pencil-square me-2"></i>Edit Patient
        <span class="badge bg-light text-dark border ms-2">@Model.PatientCode</span>
    </h4>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="PatientCode" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <h6 class="text-uppercase text-muted fw-bold mb-3 border-bottom pb-2">Personal Information</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="FirstName" class="form-label fw-semibold"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="LastName" class="form-label fw-semibold"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Gender" class="form-label fw-semibold"></label>
                    <select asp-for="Gender" class="form-select"
                            asp-items="Html.GetEnumSelectList<HealthcareCRM.Models.Gender>()"></select>
                </div>
                <div class="col-md-2">
                    <label asp-for="BloodGroup" class="form-label fw-semibold"></label>
                    <select asp-for="BloodGroup" class="form-select">
                        <option value="">—</option>
                        @foreach (var bg in new[] { "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-" })
                        {
                            <option value="@bg">@bg</option>
                        }
                    </select>
                </div>
            </div>

            <h6 class="text-uppercase text-muted fw-bold mb-3 border-bottom pb-2">Contact</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-5">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                </div>
                <div class="col-md-3">
                    <label asp-for="City" class="form-label fw-semibold"></label>
                    <input asp-for="City" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label fw-semibold"></label>
                    <input asp-for="Address" class="form-control" />
                </div>
            </div>

            <h6 class="text-uppercase text-muted fw-bold mb-3 border-bottom pb-2">Medical Notes</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="Allergies" class="form-label fw-semibold"></label>
                    <textarea asp-for="Allergies" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="Notes" class="form-label fw-semibold"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-circle me-2"></i>Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
