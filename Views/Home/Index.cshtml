@{
    ViewData["Title"] = "Dashboard";
    var totalPatients  = (int)(ViewBag.TotalPatients  ?? 0);
    var totalHistories = (int)(ViewBag.TotalHistories ?? 0);
    var todayVisits    = (int)(ViewBag.TodayVisits    ?? 0);
    var recentPatients = ViewBag.RecentPatients as List<HealthcareCRM.Models.Patient> ?? new();
}

<h4 class="fw-bold mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h4>

<!-- Stats Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-people fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-primary">@totalPatients</div>
                    <div class="text-muted small">Active Patients</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-clipboard2-pulse fs-4 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-success">@totalHistories</div>
                    <div class="text-muted small">Medical Records</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-calendar-check fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-warning">@todayVisits</div>
                    <div class="text-muted small">Today's Visits</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Patients -->
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-clock-history me-2"></i>Recently Registered Patients</span>
        <a asp-controller="Patient" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (!recentPatients.Any())
        {
            <div class="text-center py-4 text-muted">No patients registered yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th><th>Name</th><th>Age</th><th>Phone</th><th>Registered</th><th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pt in recentPatients)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark border">@pt.PatientCode</span></td>
                                <td class="fw-semibold">@pt.FullName</td>
                                <td>@pt.Age yrs</td>
                                <td>@pt.PhoneNumber</td>
                                <td class="small text-muted">@pt.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-controller="Patient" asp-action="Details" asp-route-id="@pt.Id"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
